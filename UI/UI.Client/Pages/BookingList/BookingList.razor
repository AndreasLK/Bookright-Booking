@using Facade.Bookings
@using UI.Client.Components.SearchableDataList

<SearchableDataList TItem="BookingSummaryDto"
                    Items="Bookings"
                    OnItemDoubleClick="OnBookingSelected">
    <ItemTemplate Context="booking">
        <div class="card mb-3 shadow-sm border-start border-4 @(booking.AmountPaid.HasValue ? "border-success" : "border-warning")">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start"
                     @onclick="() => OnBookingSelected.InvokeAsync(booking)"
                     style="cursor: pointer; transition: transform 0.2s;">

                    <div class="ps-2">
                        <h5 class="card-title mb-1">
                            @booking.TreatmentName
                            <span class="badge bg-light text-dark ms-2 border">@booking.ClinicName</span>
                        </h5>

                        <h6 class="card-subtitle text-muted mt-2 mb-2">
                            <i class="bi bi-person-badge"></i> @booking.CustomerName &nbsp;|&nbsp;
                            <i class="bi bi-heart-pulse"></i> @booking.PractitionerName
                        </h6>

                        <div class="text-muted small">
                            <i class="bi bi-calendar-event"></i> @booking.BookingDateFormatted &nbsp;|&nbsp;
                            <i class="bi bi-clock"></i> @booking.BookingTimeFormatted
                        </div>
                    </div>

                    <div class="text-end">
                        <span class="badge @(booking.AmountPaid.HasValue ? "bg-success" : "bg-warning text-dark") mb-2">
                            @booking.PaymentStatus
                        </span><br />

                        <button class="btn btn-outline-primary btn-sm mt-2"
                                @onclick:stopPropagation="true"
                                @onclick="() => OnBookingSelected.InvokeAsync(booking)">
                            View Details
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </ItemTemplate>
</SearchableDataList>
