@page "/bookings"
@using Facade.Bookings
@using Domain.Enums
@using UI.Client.Components.SearchableDataList

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Booking Oversigt</h1>
    </div>

    @if (_bookings is null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Indlæser...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body bg-light py-2">
                <div class="row align-items-center small text-muted font-weight-bold text-uppercase">
                    <div class="col-3 cursor-pointer" @onclick="() => ToggleSortAsync(BookingSortField.StartTime)">
                        Aftale Tidspunkt @GetSortIcon(BookingSortField.StartTime)
                    </div>
                    <div class="col-3">Kunde & Behandler</div>
                    <div class="col-3">Behandling & Klinik</div>
                    <div class="col-2 text-end cursor-pointer" @onclick="() => ToggleSortAsync(BookingSortField.AmountPaid)">
                        Betaling @GetSortIcon(BookingSortField.AmountPaid)
                    </div>
                    <div class="col-1 text-end cursor-pointer" @onclick="() => ToggleSortAsync(BookingSortField.CreatedAt)">
                        Oprettet @GetSortIcon(BookingSortField.CreatedAt)
                    </div>
                </div>
            </div>
        </div>

        <SearchableDataList TItem="BookingSummaryDto"
                            Items="_bookings"
                            OnItemDoubleClick="HandleBookingSelected">
            <ItemTemplate Context="booking">
                <div class="card mb-2 shadow-sm border-start border-4 @(booking.AmountPaid.HasValue ? "border-success" : "border-warning")">
                    <div class="card-body py-3">
                        <div class="row align-items-center">
                            <div class="col-3">
                                <div class="font-weight-bold text-primary">@booking.BookingDateFormatted</div>
                                <div class="text-muted small"><i class="bi bi-clock"></i> @booking.BookingTimeFormatted</div>
                            </div>

                            <div class="col-3">
                                <div class="font-weight-bold">@booking.CustomerName</div>
                                <div class="text-muted small"><i class="bi bi-person-badge"></i> @booking.PractitionerName</div>
                            </div>

                            <div class="col-3">
                                <div>@booking.TreatmentName</div>
                                <span class="badge bg-light text-dark border">@booking.ClinicName</span>
                            </div>

                            <div class="col-2 text-end">
                                <span class="badge @(booking.AmountPaid.HasValue ? "bg-success" : "bg-warning text-dark")">
                                    @booking.PaymentStatus
                                </span>
                                @if (booking.AmountPaid.HasValue)
                                {
                                    <div class="text-muted small mt-1">@booking.AmountPaid.Value.ToString("N2") kr.</div>
                                }
                            </div>

                            <div class="col-1 text-end">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => HandleBookingSelected(booking)">
                                    Vis
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </ItemTemplate>
        </SearchableDataList>

        @if (_hasMoreData)
        {
            <div class="text-center mt-4 mb-5">
                <button class="btn btn-secondary px-4" @onclick="LoadNextBatchAsync" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Indlæser...</span>
                    }
                    else
                    {
                        <span>Hent flere bookinger</span>
                    }
                </button>
            </div>
        }
    }
</div>
