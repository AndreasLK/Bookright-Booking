@page "/bookings"
@rendermode InteractiveAuto
@using Domain.Enums
@using Facade.Bookings
@using UI.Client.Components.EnumDropdown
@using UI.Client.Components.SearchableDataList

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Booking Oversigt</h1>
    </div>

    @if (_bookings is null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Indlæser...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body bg-light">
                <div class="row">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label class="form-label text-muted small font-weight-bold text-uppercase">Sorter Efter</label>
                        <EnumDropdown TEnum="BookingSortOption"
                                      Value="_currentSortOption"
                                      ValueChanged="OnSortOptionChangedAsync"
                                      ValueExpression="@(() => _currentSortOption)"
                                      ShowDefaultOption="false" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-muted small font-weight-bold text-uppercase">Retning</label>
                        <EnumDropdown TEnum="SortDirection"
                                      Value="_currentSortDirection"
                                      ValueChanged="OnSortDirectionChangedAsync"
                                      ValueExpression="@(() => _currentSortDirection)"
                                      ShowDefaultOption="false" />
                    </div>
                </div>
            </div>
        </div>

        <SearchableDataList TItem="BookingSummaryDto"
                            Items="_bookings"
                            OnItemDoubleClick="HandleBookingSelected">
            <ItemTemplate Context="booking">
                <div class="card mb-2 shadow-sm border-start border-4 @(booking.AmountPaid.HasValue ? "border-success" : "border-warning")">
                    <div class="card-body py-3">
                        <div class="row align-items-center">

                            <div class="col-md-3 mb-2 mb-md-0">
                                <div class="font-weight-bold text-primary">@booking.BookingDateFormatted</div>
                                <div class="text-muted small">
                                    <i class="bi bi-clock"></i> @booking.BookingTimeFormatted
                                </div>
                            </div>

                            <div class="col-md-3 mb-2 mb-md-0">
                                <div class="font-weight-bold">@booking.CustomerName</div>
                                <div class="text-muted small">
                                    <i class="bi bi-person-badge"></i> @booking.PractitionerName
                                </div>
                            </div>

                            <div class="col-md-3 mb-2 mb-md-0">
                                <div>@booking.TreatmentName</div>
                                <span class="badge bg-light text-dark border">@booking.ClinicName</span>
                            </div>

                            <div class="col-md-2 text-md-end mb-2 mb-md-0">
                                <span class="badge @(booking.AmountPaid.HasValue ? "bg-success" : "bg-warning text-dark")">
                                    @booking.PaymentStatus
                                </span>
                                @if (booking.AmountPaid.HasValue)
                                {
                                    <div class="text-muted small mt-1">@booking.AmountPaid.Value.ToString(format: "N2") kr.</div>
                                }
                            </div>

                            <div class="col-md-1 text-md-end">
                                <button class="btn btn-outline-primary btn-sm w-100" @onclick="() => HandleBookingSelected(booking)">
                                    Vis
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </ItemTemplate>
        </SearchableDataList>

        @if (_hasMoreData)
        {
            <div class="text-center mt-4 mb-5">
                <button class="btn btn-secondary px-4" @onclick="LoadNextBatchAsync" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Indlæser...</span>
                    }
                    else
                    {
                        <span>Hent flere bookinger</span>
                    }
                </button>
            </div>
        }
    }
</div>
