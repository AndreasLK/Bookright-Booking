@namespace UI.Client.Components.SearchableDataList
@typeparam TItem

<div class="searchable-data-list">
    <input type="text"
           class="form-control mb-2"
           placeholder="Søg..."
           @bind="SearchTerm"
           @bind:event="oninput" />

    <div class="list-group shadow-sm" style="max-height: 200px; overflow-y: auto;">
        @foreach (var item in FilteredItems)
        {
            <button type="button"
                    class="list-group-item list-group-item-action"
                    @onclick="() => HandleItemClickAsync(item)"
                    @ondblclick="() => HandleItemDoubleClickAsync(item)">
                @ItemTemplate(item)
            </button>
        }

        @if (!FilteredItems.Any())
        {
            <div class="text-muted p-3 text-center">
                <small>Ingen resultater fundet.</small>
            </div>
        }
    </div>
</div>
